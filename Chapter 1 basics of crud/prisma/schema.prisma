generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Bookings {
  id        String   @id @default(uuid())
  location  String
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
